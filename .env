# BikerZone Environment Variables
# Copy this file to .env and fill in your values

# ======================
# APPLICATION
# ======================
NODE_ENV=development
PORT=3000

# ======================
# DATABASE - PostgreSQL
# ======================
DATABASE_HOST=postgres
DATABASE_PORT=5432
DATABASE_USER=bikerzone
DATABASE_PASSWORD=biker_secure_2024
DATABASE_NAME=bikerzone_db

# ======================
# DATABASE - MongoDB
# ======================
MONGODB_URI=mongodb://bikerzone:mongo_secure_2024@mongodb:27017/bikerzone_social?authSource=admin

# ======================
# CACHE - Redis
# ======================
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=redis_secure_2024

# ======================
# JWT AUTHENTICATION
# ======================
JWT_SECRET=bikerzone-jwt-secret-key-change-in-production
JWT_EXPIRATION=15m
JWT_REFRESH_SECRET=bikerzone-refresh-secret-key-change-in-production
JWT_REFRESH_EXPIRATION=7d

# ======================
# CLOUDINARY (Optional - for image/video upload)
# ======================
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ======================
# SENDGRID (Optional - for emails)
# ======================
SENDGRID_API_KEY=
FROM_EMAIL=noreply@bikerzone.com

# ======================
# FIREBASE (Optional - for push notifications)
# ======================
FCM_SERVER_KEY=

# ======================
# GOOGLE MAPS API (Optional - for maps)
# ======================
GOOGLE_MAPS_API_KEY=

# ======================
# TWILIO (Optional - for SMS)
# ======================
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# ======================
# FRONTEND URLs
# ======================
FRONTEND_URL=http://localhost:8080
BACKEND_URL=http://localhost:3000

# ======================
# CORS ORIGINS
# ======================
CORS_ORIGINS=http://localhost:8080,http://localhost:3000
